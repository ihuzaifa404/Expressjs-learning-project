{
    "tabWidth": 2,
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "all",
    "arrowParens": "always",
    "semi": true,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "endOfLine": "lf",
    "useTabs": false,
    "useSpaces": true,
    "spaces": 2,
    "spaceBeforeFunctionParen": false
}